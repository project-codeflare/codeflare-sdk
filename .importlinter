[importlinter]
root_package = codeflare_sdk
include_external_packages = False

# CI-enforced layer boundaries (RHOAIENG-61477 §3.3).
# Contracts target production modules only; test files and known transitive
# imports (e.g. `import codeflare_sdk` for version lookup) are grandfathered.
# Additional boundaries are documented in path-scoped rules as prose-only.

[importlinter:contract:1]
name = Ray client module is isolated from internal packages
type = forbidden
source_modules =
    codeflare_sdk.ray.client.ray_jobs
forbidden_modules =
    codeflare_sdk.common
    codeflare_sdk.ray.cluster
    codeflare_sdk.ray.rayjobs
    codeflare_sdk.vendored

[importlinter:contract:2]
name = Foundation utils must not import Ray feature modules
type = forbidden
source_modules =
    codeflare_sdk.common.utils.constants
    codeflare_sdk.common.utils.utils
    codeflare_sdk.common.utils.validation
    codeflare_sdk.common.utils.k8s_utils
    codeflare_sdk.common.utils.generate_cert
    codeflare_sdk.common.utils.demos
forbidden_modules =
    codeflare_sdk.ray

[importlinter:contract:3]
name = Kueue and auth modules must not import Ray feature modules
type = forbidden
source_modules =
    codeflare_sdk.common.kueue.kueue
    codeflare_sdk.common.kubernetes_cluster.auth
    codeflare_sdk.common.kubernetes_cluster.kube_api_helpers
forbidden_modules =
    codeflare_sdk.ray

[importlinter:contract:4]
name = Vendored KubeRay client only imported by rayjob module
type = forbidden
source_modules =
    codeflare_sdk.common.kubernetes_cluster.auth
    codeflare_sdk.common.kubernetes_cluster.kube_api_helpers
    codeflare_sdk.common.kueue.kueue
    codeflare_sdk.common.utils.constants
    codeflare_sdk.common.utils.utils
    codeflare_sdk.common.utils.validation
    codeflare_sdk.common.utils.k8s_utils
    codeflare_sdk.common.utils.generate_cert
    codeflare_sdk.common.utils.demos
    codeflare_sdk.ray.cluster.cluster
    codeflare_sdk.ray.cluster.build_ray_cluster
    codeflare_sdk.ray.cluster.config
    codeflare_sdk.ray.cluster.status
    codeflare_sdk.ray.cluster.pretty_print
    codeflare_sdk.ray.client.ray_jobs
forbidden_modules =
    codeflare_sdk.vendored
ignore_imports =
    codeflare_sdk.ray.cluster.build_ray_cluster -> codeflare_sdk
    codeflare_sdk.ray.cluster.cluster -> codeflare_sdk.common.widgets.widgets
    codeflare_sdk.common.widgets.widgets -> codeflare_sdk
